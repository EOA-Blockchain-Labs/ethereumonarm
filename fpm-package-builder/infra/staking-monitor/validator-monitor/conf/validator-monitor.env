#!/bin/bash
# =============================================================================
# validator-monitor.env — Configuration for standalone validator monitoring.
# Fill in every value before running any script.
# Installed to: /home/ethereum/.validator-monitor/conf/validator-monitor.env
# =============================================================================

# -----------------------------------------------------------------------------
# Node identity (shown in Telegram alerts)
# -----------------------------------------------------------------------------
NODE_NAME="validator-node"        # human-readable label for this machine

# -----------------------------------------------------------------------------
# Telegram
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=""             # from @BotFather
TELEGRAM_CHAT_ID=""               # your group or user chat ID

# -----------------------------------------------------------------------------
# Validator keys directory
# The directory that contains EIP-2335 keystore .json files.
# Each file must have a top-level "pubkey" field.
#
# Common locations per client:
#   Lighthouse : /home/ethereum/.lighthouse/mainnet/validators/
#   Teku       : /home/ethereum/.teku/validator/key-manager/local/
#   Prysm      : /home/ethereum/.prysm-beacon/validator/  (keymanager dir)
#   Nimbus     : /home/ethereum/.nimbus-beacon/validators/
#   Lodestar   : /home/ethereum/.lodestar-beacon/validator/keystores/
#   Grandine   : /home/ethereum/.grandine-beacon/mainnet/validator/
#
# The directory may contain subdirectories — the script scans recursively.
# -----------------------------------------------------------------------------
KEYSTORE_DIR="/home/ethereum/.lighthouse/mainnet/validators"

# -----------------------------------------------------------------------------
# Ethereum client service names
# Used in alert messages to show the correct journalctl command.
# Common values:
#   VALIDATOR_SERVICE : lighthouse-validator | prysm-validator | nimbus-validator
#                       teku-validator | lodestar-validator | grandine-validator
#   BEACON_SERVICE    : lighthouse-beacon | prysm-beacon | nimbus-beacon etc.
#   CL_SERVICE        : same as BEACON_SERVICE (alias used in some checks)
# -----------------------------------------------------------------------------
VALIDATOR_SERVICE=""              # <CHANGE_ME> e.g. lighthouse-validator
BEACON_SERVICE=""                 # <CHANGE_ME> e.g. lighthouse-beacon
CL_SERVICE=""                     # <CHANGE_ME> same as BEACON_SERVICE

# -----------------------------------------------------------------------------
# Beacon node API
# The local consensus client Beacon API endpoint (port 5052 by default).
# All major clients expose this standard API.
# -----------------------------------------------------------------------------
CL_API="http://localhost:5052"

# -----------------------------------------------------------------------------
# Index cache
# Path where the pubkey → validator index map is stored.
# Updated by sync-indices.sh. Read by validator-duties.sh.
# -----------------------------------------------------------------------------
INDEX_CACHE="/home/ethereum/.validator-monitor/cache/validator-indices.json"

# -----------------------------------------------------------------------------
# Alert thresholds
# -----------------------------------------------------------------------------
# Number of consecutive missed attestations before alerting.
# 1 = alert on every single missed attestation (recommended for production).
MISSED_ATT_THRESHOLD=1

# If this many or more validators miss the same epoch, suppress individual
# per-validator alerts and send a single global cluster/ISP outage alert.
MASS_MISS_THRESHOLD=10

# Alert on any missed block proposal (1 = always alert, cannot be 0).
# Block proposals are rare and every miss is significant.
MISSED_PROPOSAL_ALERT=true

# How many past epochs to check for missed proposals on each cron run.
# Keeps a rolling window to catch any we may have missed between runs.
PROPOSAL_CHECK_EPOCHS=3

# -----------------------------------------------------------------------------
# Locking / deduplication
# An alert fires at most once per epoch per validator.
# Locks are keyed by validator_index + epoch so each epoch is independent.
# -----------------------------------------------------------------------------
LOCK_DIR="/home/ethereum/.validator-monitor/locks"
LOCK_EXPIRY=86400                 # 24 hours — stale locks are auto-expired
