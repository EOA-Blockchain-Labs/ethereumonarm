#!/bin/bash

# ==============================================================================
# Script Name: setup_validator_passwords.sh
# Description: Prompts for the validator password and creates matching .txt
#              password files for Ethereum validator keystores (.json).
#              Enforces file permissions (600) for security.
# ==============================================================================

# ------------------------------------------------------------------------------
# Safety & Configuration
# ------------------------------------------------------------------------------
set -euo pipefail  # Fail on error, unset variables, or pipe failures

# Default configuration
DEFAULT_DIR="/home/ethereum/validator_keys"

# ANSI Colors for logging
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# ------------------------------------------------------------------------------
# Helper Functions
# ------------------------------------------------------------------------------

log_info() {
    echo -e "[INFO] $1"
}

log_success() {
    echo -e "${GREEN}[SUCCESS] $1${NC}"
}

log_warn() {
    echo -e "${YELLOW}[WARN] $1${NC}"
}

log_error() {
    echo -e "${RED}[ERROR] $1${NC}" >&2
}



get_user_password() {
    local pass
    while true; do
        echo -n "Enter the password for your validator keystores: "
        read -rs pass
        echo ""
        
        if [[ -z "$pass" ]]; then
            log_warn "Password cannot be empty."
        else
            echo "$pass"
            return 0
        fi
    done
}

get_valid_directory() {
    local target_dir="${1:-$DEFAULT_DIR}"
    
    # Check if directory exists
    if [[ ! -d "$target_dir" ]]; then
        log_error "Directory not found: $target_dir"
        log_info "Usage: setup_validator_passwords [directory]"
        exit 1
    fi
    
    # Check if directory contains .json files
    if ! ls "$target_dir"/*.json &> /dev/null; then
        log_error "No .json keystore files found in: $target_dir"
        exit 1
    fi
    
    echo "$target_dir"
}

# ------------------------------------------------------------------------------
# Main Execution
# ------------------------------------------------------------------------------

main() {
    log_info "Starting validator password setup..."
    
    # 1. Get and validate the directory
    KEYSTORE_DIR=$(get_valid_directory "$1")
    log_info "Using directory: $KEYSTORE_DIR"

    # 2. Get the password from the user
    VALIDATOR_PASS=$(get_user_password)
    
    # 3. Process files
    count=0
    
    # Use a for loop with find to handle filenames with spaces correctly
    while IFS= read -r -d '' json_file; do
        # Construct the txt filename
        txt_file="${json_file%.json}.txt"
        
        # Write password without trailing newline
        echo -n "$VALIDATOR_PASS" > "$txt_file"
        
        # SECURITY: Set permissions to 600 (Read/Write for owner ONLY)
        chmod 600 "$txt_file"
        
        ((count++))
    done < <(find "$KEYSTORE_DIR" -maxdepth 1 -name "*.json" -type f -print0)

    # 4. Final Report
    echo ""
    log_success "Processing complete."
    log_info "Files generated: $count"
    log_info "Permissions set to 600 (owner only) for security."
    
    echo "------------------------------------------------------------"
    log_info "The password files have been created successfully."
    echo "------------------------------------------------------------"
}

# Run Main
main "$@"
