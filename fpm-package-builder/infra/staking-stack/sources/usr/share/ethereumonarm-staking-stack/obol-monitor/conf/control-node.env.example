#!/bin/bash
# =============================================================================
# control-node.env — Configuration for Obol DVT control/backup node
# Copy to: /home/ethereum/.obol-monitor/conf/node.env
# All values are written by install.sh. Edit manually only if needed.
# =============================================================================

# -----------------------------------------------------------------------------
# Node identity
# -----------------------------------------------------------------------------
NODE_TYPE="__NODE_TYPE__"    # control | control-failover — written by install.sh
NODE_ID="__NODE_ID__"
NODE_NAME="__NODE_NAME__"
HOSTNAME=$(hostname)

# -----------------------------------------------------------------------------
# Telegram
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN="__TELEGRAM_BOT_TOKEN__"
TELEGRAM_CHAT_ID="__TELEGRAM_CHAT_ID__"

# -----------------------------------------------------------------------------
# Local Ethereum clients (full node + MEV — backup validators)
# Supported EL: geth | nethermind | erigon | besu | reth | ethrex
# Supported CL: lighthouse | prysm | nimbus | teku | lodestar | grandine
# -----------------------------------------------------------------------------
# Auto-detected by install.sh from running systemd services.
# Edit manually only if auto-detection produced a wrong result.
EL_CLIENT="__EL_CLIENT__"
CL_CLIENT="__CL_CLIENT__"
NETWORK="__NETWORK__"

EL_SERVICE="__EL_SERVICE__"                 # e.g. geth  or  geth-hoodi
CL_SERVICE="__CL_SERVICE__"                 # e.g. lighthouse-beacon-mev
MEV_SERVICE="__MEV_SERVICE__"               # e.g. mev-boost  or  mev-boost-hoodi
OBOL_RELAY_SERVICE="charon-relay"
VALIDATOR_SERVICE="__VALIDATOR_SERVICE__"   # e.g. lighthouse-validator  (standard, not DVT variant)

# -----------------------------------------------------------------------------
# Local API endpoints
# -----------------------------------------------------------------------------
EL_RPC="http://localhost:8545"
CL_API="http://localhost:5052"

# -----------------------------------------------------------------------------
# Obol cluster — size and node IPs/labels
# All checks use Charon's HTTP API on port 3620 over VPN/Tailscale.
# No SSH needed. Ensure port 3620 is reachable from this control node.
# CLUSTER_SIZE, OBOL_NODE_*_IP and OBOL_NODE_*_NAME are written by install.sh.
# -----------------------------------------------------------------------------
CLUSTER_SIZE="__CLUSTER_SIZE__"         # total number of Obol nodes

# Node IPs, names and Charon API base URLs — one entry per node.
# install.sh writes as many entries as CLUSTER_SIZE specifies.
__OBOL_NODES_BLOCK__

# Expected Charon peers per node = cluster_size - 1 (set by install.sh)
CHARON_PEERS_EXPECTED="__CHARON_PEERS_EXPECTED__"
CHARON_API_TIMEOUT=8              # seconds for curl calls to Charon :3620

# -----------------------------------------------------------------------------
# Alert thresholds — local services
# -----------------------------------------------------------------------------
EL_PEERS_MIN=5
CL_PEERS_MIN=10

SWAP_ALERT_GB=10
DISK_ETH_ALERT_GB=150
DISK_ROOT_ALERT_PCT=85
CPU_TEMP_ALERT_C=80

# Charon
CHARON_PEERS_MIN=2               # connected peers must meet this minimum
CHARON_LATENCY_ALERT_MS=500      # alert if any peer RTT exceeds this (ms)

# -----------------------------------------------------------------------------
# Lock / deduplication
# -----------------------------------------------------------------------------
LOCK_DIR="/home/ethereum/.obol-monitor/locks"
LOCK_EXPIRY=86400

# -----------------------------------------------------------------------------
# VPN (Tailscale) — optional, used in alert messages
# -----------------------------------------------------------------------------
VPN_IP="__VPN_IP__"              # This node's Tailscale/VPN IP (e.g. 100.x.x.x), leave empty if not used

# -----------------------------------------------------------------------------
# Control node redundancy — primary / backup
#
# If PEER_CONTROL_IP is set, health scripts check whether the peer control
# node is reachable over VPN before running. If the peer responds, this node
# skips its checks (the peer is handling them). If the peer is unreachable,
# this node takes over and runs the full check.
#
# Set to the primary control node's VPN IP on the failover node.
# Left empty on the primary node (install.sh sets this automatically).
# -----------------------------------------------------------------------------
PEER_CONTROL_IP="__PEER_CONTROL_IP__"   # VPN IP of the other control node; empty = always run (primary)
PEER_CHECK_TIMEOUT=5                     # seconds to wait for each probe (EL, relay, ping)
PEER_RETRY_DELAY=10                      # seconds to wait before ping after EL+relay both fail
PEER_RELAY_PORT=3640                     # Charon relay port — used as secondary liveness check

# The failover node queries the primary's EL API as a second liveness check.
# EOA nginx proxies port 80 → EL port 8545, so PEER_CONTROL_IP is used directly.
# No extra variable needed — the EL query goes to the same IP as the ping.

# Primary node monitors the failover node health.
# Set FAILOVER_CONTROL_IP on the PRIMARY to the failover node's VPN IP.
# Leave empty on the failover node (install.sh sets this automatically).
FAILOVER_CONTROL_IP="__FAILOVER_CONTROL_IP__"  # VPN IP of the failover node; empty on the failover itself

# -----------------------------------------------------------------------------
# Validator duties monitoring
# Integrated from validator-monitor — checks missed attestations and proposals
# for all validators using the local beacon API.
# -----------------------------------------------------------------------------
# Path to cluster-lock.json (group cluster only — copy from an Obol node)
# Leave empty for solo cluster
CLUSTER_LOCK_FILE="__CLUSTER_LOCK_FILE__"

KEYSTORE_DIR="__KEYSTORE_DIR__"          # directory containing EIP-2335 keystore .json files
INDEX_CACHE="/home/ethereum/.obol-monitor/cache/validator-indices.json"
MISSED_ATT_THRESHOLD=1

# How many epochs without a new attestation duty before alerting VC is inactive.
# Default 2 (~13 min). Increase if your cluster has frequent restarts.
VC_INACTIVE_EPOCHS=2

# If this many or more validators miss the same epoch, suppress individual
# per-validator alerts and send a single global cluster/ISP outage alert.
MASS_MISS_THRESHOLD=10
MISSED_PROPOSAL_ALERT=true
PROPOSAL_CHECK_EPOCHS=3
