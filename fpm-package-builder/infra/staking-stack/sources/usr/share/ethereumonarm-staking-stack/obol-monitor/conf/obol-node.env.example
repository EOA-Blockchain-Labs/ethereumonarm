#!/bin/bash
# =============================================================================
# obol-node.env — Configuration for Obol DVT cluster node
# Copy to: /home/ethereum/.obol-monitor/conf/node.env
# All values are written by install.sh. Edit manually only if needed.
# =============================================================================

# -----------------------------------------------------------------------------
# Node identity
# -----------------------------------------------------------------------------
NODE_TYPE="obol"
NODE_ID="__NODE_ID__"
NODE_NAME="__NODE_NAME__"
USING_LIDO="__USING_LIDO__"       # yes | no
CLUSTER_SIZE="__CLUSTER_SIZE__"   # total number of nodes in the Obol cluster
HOSTNAME=$(hostname)

# -----------------------------------------------------------------------------
# Telegram
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN="__TELEGRAM_BOT_TOKEN__"
TELEGRAM_CHAT_ID="__TELEGRAM_CHAT_ID__"

# -----------------------------------------------------------------------------
# Ethereum clients
# These values are auto-detected by install.sh from running systemd services.
# Supported EL: geth | nethermind | erigon | besu | reth | ethrex
# Supported CL: lighthouse | prysm | nimbus | teku | lodestar | grandine
# Edit manually only if auto-detection produced a wrong result.
# -----------------------------------------------------------------------------
EL_CLIENT="__EL_CLIENT__"
CL_CLIENT="__CL_CLIENT__"
NETWORK="__NETWORK__"

# Resolved service names — these follow Ethereum on ARM conventions.
# MEV variants are always used on Obol nodes (validators require MEV Boost).
EL_SERVICE="__EL_SERVICE__"                 # e.g. geth  or  geth-hoodi
CL_SERVICE="__CL_SERVICE__"                 # e.g. lighthouse-beacon-mev
MEV_SERVICE="__MEV_SERVICE__"               # e.g. mev-boost  or  mev-boost-hoodi
CHARON_SERVICE="charon"
VALIDATOR_SERVICE="__VALIDATOR_SERVICE__"   # e.g. lighthouse-validator-obol  or  lighthouse-validator-hoodi-obol

# -----------------------------------------------------------------------------
# Local API endpoints
# These are standard Ethereum on ARM defaults. Change only if customised.
# -----------------------------------------------------------------------------
EL_RPC="http://localhost:8545"
CL_API="http://localhost:5052"
CHARON_METRICS="http://localhost:3620/metrics"
CHARON_API="http://localhost:3600"

# -----------------------------------------------------------------------------
# Alert thresholds
# -----------------------------------------------------------------------------
# Peers
EL_PEERS_MIN=5            # Alert if EL connected peers fall below this
CL_PEERS_MIN=10           # Alert if CL connected peers fall below this
CHARON_PEERS_MIN="__CHARON_PEERS_MIN__"  # cluster_size - 1; set by install.sh
CHARON_LATENCY_ALERT_MS=500  # Alert if any peer p50 RTT exceeds this (ms)
CHARON_API_TIMEOUT=8      # seconds for curl calls to Charon :3620

# Memory
SWAP_ALERT_GB=10           # Alert if swap usage exceeds this (GB)

# Disk
DISK_ETH_ALERT_GB=150     # Alert if /home/ethereum free space falls below (GB)
DISK_ROOT_ALERT_PCT=85    # Alert if / used% exceeds this percentage

# CPU temperature
CPU_TEMP_ALERT_C=80       # Alert if any thermal zone exceeds this (°C)

# -----------------------------------------------------------------------------
# Lock / deduplication settings
# An alert is sent at most once per LOCK_EXPIRY window for each condition.
# -----------------------------------------------------------------------------
LOCK_DIR="/home/ethereum/.obol-monitor/locks"
LOCK_EXPIRY=86400         # 24 hours in seconds

# -----------------------------------------------------------------------------
# VPN (Tailscale) — optional, used in alert messages
# -----------------------------------------------------------------------------
VPN_IP="__VPN_IP__"          # This node's Tailscale/VPN IP (e.g. 100.x.x.x), leave empty if not used
