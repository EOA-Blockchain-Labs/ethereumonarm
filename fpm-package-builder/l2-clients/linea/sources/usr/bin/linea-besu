# Attempt to set APP_HOME
# Resolve links: $0 may be a link
PRG="$0"
# Need this for relative symlinks.
while [ -h "$PRG" ] ; do
    ls=`ls -ld "$PRG"`
    link=`expr "$ls" : '.*-> \(.*\)$'`
    if expr "$link" : '/.*' > /dev/null; then
        PRG="$link"
    else
        PRG=`dirname "$PRG"`"/$link"
    fi
done
SAVED="`pwd`"
cd "`dirname \"$PRG\"`/.." >/dev/null
APP_HOME="/usr/share/linea/"
cd "$SAVED" >/dev/null

APP_NAME="besu"
APP_BASE_NAME=`basename "$0"`

# Use the maximum available, or set MAX_FD != -1 to use that value.
MAX_FD="maximum"

warn () {
    echo "$*"
}

die () {
    echo
    echo "$*"
    echo
    exit 1
}

# OS specific support (must be 'true' or 'false').
cygwin=false
msys=false
darwin=false
nonstop=false
case "`uname`" in
  CYGWIN* )
    cygwin=true
    ;;
  Darwin* )
    darwin=true
    ;;
  MSYS* | MINGW* )
    msys=true
    ;;
  NONSTOP* )
    nonstop=true
    ;;
esac

CLASSPATH=$APP_HOME/lib/besu-25.11.0-linea4.2.jar:$APP_HOME/lib/besu-ethereum-evmtool-25.11.0-linea4.2.jar:$APP_HOME/lib/besu-app-25.11.0-linea4.2.jar:$APP_HOME/lib/besu-ethereum-ethstats-25.11.0-linea4.2.jar:$APP_HOME/lib/besu-consensus-clique-25.11.0-linea4.2.jar:$APP_HOME/lib/besu-consensus-qbft-25.11.0-linea4.2.jar:$APP_HOME/lib/besu-consensus-ibftlegacy-25.11.0-linea4.2.jar:$APP_HOME/lib/besu-consensus-ibft-25.11.0-linea4.2.jar:$APP_HOME/lib/besu-consensus-qbft-core-25.11.0-linea4.2.jar:$APP_HOME/lib/besu-consensus-common-25.11.0-linea4.2.jar:$APP_HOME/lib/besu-ethereum-api-25.11.0-linea4.2.jar:$APP_HOME/lib/besu-ethereum-referencetests-25.11.0-linea4.2.jar:$APP_HOME/lib/besu-consensus-merge-25.11.0-linea4.2.jar:$APP_HOME/lib/besu-ethereum-blockcreation-25.11.0-linea4.2.jar:$APP_HOME/lib/besu-plugins-rocksdb-25.11.0-linea4.2.jar:$APP_HOME/lib/besu-ethereum-eth-25.11.0-linea4.2.jar:$APP_HOME/lib/besu-ethereum-permissioning-25.11.0-linea4.2.jar:$APP_HOME/lib/besu-ethereum-p2p-25.11.0-linea4.2.jar:$APP_HOME/lib/besu-ethereum-core-25.11.0-linea4.2.jar:$APP_HOME/lib/besu-ethereum-core-support-test-25.11.0-linea4.2-test-support.jar:$APP_HOME/lib/besu-config-25.11.0-linea4.2.jar:$APP_HOME/lib/besu-ethereum-trie-25.11.0-linea4.2.jar:$APP_HOME/lib/besu-crypto-services-25.11.0-linea4.2.jar:$APP_HOME/lib/besu-metrics-rocksdb-25.11.0-linea4.2.jar:$APP_HOME/lib/besu-services-pipeline-25.11.0-linea4.2.jar:$APP_HOME/lib/besu-services-tasks-25.11.0-linea4.2.jar:$APP_HOME/lib/besu-metrics-core-25.11.0-linea4.2.jar:$APP_HOME/lib/besu-services-kvstore-25.11.0-linea4.2.jar:$APP_HOME/lib/besu-plugin-api-25.11.0-linea4.2.jar:$APP_HOME/lib/besu-evm-25.11.0-linea4.2.jar:$APP_HOME/lib/besu-datatypes-25.11.0-linea4.2.jar:$APP_HOME/lib/besu-nat-25.11.0-linea4.2.jar:$APP_HOME/lib/besu-ethereum-rlp-25.11.0-linea4.2.jar:$APP_HOME/lib/besu-util-25.11.0-linea4.2.jar:$APP_HOME/lib/besu-crypto-algorithms-25.11.0-linea4.2.jar:$APP_HOME/lib/hibernate-validator-8.0.2.Final.jar:$APP_HOME/lib/jakart