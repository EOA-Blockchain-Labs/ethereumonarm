#!/bin/bash

# ==============================================================================
# Script Name: setup_validator_passwords.sh
# Description: Prompts for the validator password and creates matching .txt
#              password files for Ethereum validator keystores (.json).
#              Enforces file permissions (600) for security.
# ==============================================================================

set -euo pipefail

DEFAULT_DIR="/home/ethereum/validator_keys"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log_info() {
    echo -e "[INFO] $1"
}

log_success() {
    echo -e "${GREEN}[SUCCESS] $1${NC}"
}

log_warn() {
    echo -e "${YELLOW}[WARN] $1${NC}"
}

log_error() {
    echo -e "${RED}[ERROR] $1${NC}" >&2
}

get_user_password() {
    local pass1 pass2

    while true; do
        printf "Enter validator keystore password (will be used for ALL .txt files): " > /dev/tty
        read -r -s pass1 < /dev/tty
        printf "\n\n" > /dev/tty

        printf "Confirm password: " > /dev/tty
        read -r -s pass2 < /dev/tty
        printf "\n" > /dev/tty

        if [[ -z "$pass1" ]]; then
            log_error "Password cannot be empty."
            continue
        fi

        if [[ "$pass1" != "$pass2" ]]; then
            log_error "Passwords do not match. Try again."
            continue
        fi

        echo "$pass1"
        return 0
    done
}

get_valid_directory() {
    local target_dir="${1:-$DEFAULT_DIR}"

    # If default directory does not exist, ask for a custom one (to TTY so stdout stays clean)
    if [[ "$target_dir" == "$DEFAULT_DIR" && ! -d "$target_dir" ]]; then
        printf "%b\n" "${YELLOW}[WARN] Default directory not found: $DEFAULT_DIR${NC}" > /dev/tty
        printf "Enter the directory containing keystore .json files: " > /dev/tty
        read -r target_dir < /dev/tty
    fi

    # Keep asking until a valid directory is provided
    while [[ ! -d "$target_dir" ]]; do
        printf "%b\n" "${RED}[ERROR] Directory not found: $target_dir${NC}" > /dev/tty
        printf "Enter a valid directory path: " > /dev/tty
        read -r target_dir < /dev/tty
    done

    # Ensure keystore*.json files exist (not any *.json)
    if ! ls "$target_dir"/keystore*.json &> /dev/null; then
        log_error "No keystore*.json files found in: $target_dir"
        exit 1
    fi

    # IMPORTANT: stdout must contain ONLY the directory path for command substitution
    echo "$target_dir"
}

main() {
    log_info "Starting validator password setup..."

    # 1. Get and validate the directory (optional CLI argument)
    KEYSTORE_DIR="$(get_valid_directory "${1:-}")"
    log_info "Using directory: $KEYSTORE_DIR"

    # 2. Get the password from the user
    VALIDATOR_PASS="$(get_user_password)"

    # 3. Process only keystore*.json files
    count=0
    shopt -s nullglob

    for json_file in "$KEYSTORE_DIR"/keystore*.json; do
        base_name="$(basename "$json_file" .json)"
        txt_file="$KEYSTORE_DIR/${base_name}.txt"

        printf '%s\n' "$VALIDATOR_PASS" > "$txt_file"
        chmod 600 "$txt_file"

        count=$((count + 1))
    done

    shopt -u nullglob

    # 4. Final report
    echo ""
    log_success "Processing complete."
    log_info "Files generated: $count"
    log_info "Permissions set to 600 (owner only) for security."

    echo "------------------------------------------------------------"
    log_info "The password files have been created successfully."
    echo "------------------------------------------------------------"
}

main "${1:-}"
