#!/bin/sh
# postinst script for dirk
#
# See: dh_installdeb(1)

set -e

case "$1" in
    configure)
        # Set ownership and permissions for the dirk directory
        # The package includes /etc/ethereum/dirk/dirk.yml by default,
        # so this sets the correct permissions for the runtime user.
        if id "ethereum" >/dev/null 2>&1; then
            chown -R ethereum:ethereum /etc/ethereum/dirk
        fi
        chmod 755 /etc/ethereum/dirk
        if [ -f /etc/ethereum/dirk/dirk.yml ]; then
            chmod 644 /etc/ethereum/dirk/dirk.yml
        fi
    ;;

    abort-upgrade|abort-remove|abort-deconfigure)
    ;;

    *)
        echo "postinst called with unknown argument \`$1'" >&2
        exit 1
    ;;
esac

# dh_installdeb will replace this with shell code automatically
# generated by other debhelper scripts.

#DEBHELPER#

exit 0
