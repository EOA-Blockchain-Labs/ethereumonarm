#!/bin/bash

# ==============================================================================
# Script Name: setup_validator_passwords.sh
# Description: Generates a secure random password and creates matching .txt
#              password files for Ethereum validator keystores (.json).
#              Enforces file permissions (600) for security.
# ==============================================================================

# ------------------------------------------------------------------------------
# Safety & Configuration
# ------------------------------------------------------------------------------
set -euo pipefail  # Fail on error, unset variables, or pipe failures

# Default configuration
DEFAULT_DIR="/home/ethereum/validator_keys"
PASSWORD_LENGTH=32
BACKUP_FILE="password_backup_$(date +%Y%m%d_%H%M%S).txt"

# ANSI Colors for logging
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# ------------------------------------------------------------------------------
# Helper Functions
# ------------------------------------------------------------------------------

log_info() {
    echo -e "[INFO] $1"
}

log_success() {
    echo -e "${GREEN}[SUCCESS] $1${NC}"
}

log_warn() {
    echo -e "${YELLOW}[WARN] $1${NC}"
}

log_error() {
    echo -e "${RED}[ERROR] $1${NC}" >&2
}

check_dependencies() {
    if ! command -v openssl &> /dev/null; then
        log_error "OpenSSL is not installed. Please install it and try again."
        exit 1
    fi
}

get_valid_directory() {
    local target_dir="$DEFAULT_DIR"
    
    while true; do
        # Check if directory exists
        if [[ ! -d "$target_dir" ]]; then
            log_warn "Directory not found: $target_dir"
        
        # Check if directory contains .json files
        elif ! ls "$target_dir"/*.json &> /dev/null; then
            log_warn "No .json keystore files found in: $target_dir"
        
        # If both checks pass, we are good
        else
            echo "$target_dir"
            return 0
        fi

        # Prompt user for input if checks failed
        read -r -p "Please enter the valid path to your keystores: " target_dir
        
        # Remove trailing slash if present for consistency
        target_dir="${target_dir%/}"
    done
}

# ------------------------------------------------------------------------------
# Main Execution
# ------------------------------------------------------------------------------

main() {
    log_info "Starting validator password setup..."
    
    check_dependencies

    # 1. Get and validate the directory
    KEYSTORE_DIR=$(get_valid_directory)
    log_info "Using directory: $KEYSTORE_DIR"

    # 2. Generate a secure random password (hex encoded)
    # Using 16 bytes = 32 hex characters
    SECURE_PASS=$(openssl rand -hex 16)
    
    # 3. Process files
    count=0
    
    # We use find/while to handle filenames with spaces correctly
    while IFS= read -r json_file; do
        # Construct the txt filename
        txt_file="${json_file%.json}.txt"
        
        # Write password without trailing newline
        echo -n "$SECURE_PASS" > "$txt_file"
        
        # SECURITY: Set permissions to 600 (Read/Write for owner ONLY)
        chmod 600 "$txt_file"
        
        ((count++))
    done < <(find "$KEYSTORE_DIR" -maxdepth 1 -name "*.json" -type f)

    # 4. Save a master backup for the user
    echo "$SECURE_PASS" > "$BACKUP_FILE"
    chmod 600 "$BACKUP_FILE"

    # 5. Final Report
    echo ""
    log_success "Processing complete."
    log_info "Files generated: $count"
    log_info "Permissions set to 600 (owner only) for security."
    
    echo "------------------------------------------------------------"
    echo -e "MASTER PASSWORD: ${YELLOW}$SECURE_PASS${NC}"
    echo "------------------------------------------------------------"
    log_warn "A backup of this password has been saved to: $BACKUP_FILE"
    log_warn "Please store this password securely immediately."
}

# Run Main
main
